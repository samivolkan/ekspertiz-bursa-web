# Public Google Tag Manager container id, for example GTM-XXXXXXX.
NEXT_PUBLIC_GTM_ID=

# Direct GA4 measurement id for the production website. Used only when GTM is not configured.
NEXT_PUBLIC_GA4_MEASUREMENT_ID=G-K6LBGJQ8T1

# Optional daily workflow notifications are configured as GitHub Actions secrets:
# SLACK_WEBHOOK_URL
# DISCORD_WEBHOOK_URL
# PAGESPEED_API_KEY

# Optional FTP deploy defaults. Do not write real passwords here.
FTP_HOST=ftp.bursaekspertiz.com
FTP_PORT=21
FTP_USER=
FTP_REMOTE_DIR=/public_html
FTP_SECURE=true
