{
  "name": "ekspertiz-bursa-web",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "dev": "vinext dev",
    "build": "vinext build",
    "build:static-hosting": "node scripts/build-static-hosting.mjs",
    "deploy:ftp": "node scripts/deploy-ftp.mjs",
    "audit:seo": "node scripts/audit-static-seo.mjs",
    "audit:live": "node scripts/audit-live.mjs",
    "seo:audit": "node scripts/seo-audit/index.mjs --source out --label local",
    "seo:audit:local": "node scripts/seo-audit/index.mjs --source out --label local",
    "seo:audit:production": "node scripts/seo-audit/index.mjs --url https://www.bursaekspertiz.com --label production",
    "seo:audit:fix": "node scripts/seo-audit/fix.mjs",
    "seo:audit:fix:dry": "node scripts/seo-audit/fix.mjs --dry-run",
    "seo:audit:report": "node scripts/seo-audit/index.mjs --report-only --label production",
    "start": "vinext start",
    "test": "npm run build && node --test tests/*.test.mjs",
    "lint": "eslint app components db lib scripts/seo-audit worker tests vite.config.ts next.config.ts drizzle.config.ts eslint.config.mjs",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate"
  },
  "dependencies": {
    "@fontsource-variable/plus-jakarta-sans": "^5.2.8",
    "@fontsource-variable/rubik": "^5.2.8",
    "drizzle-orm": "0.45.2",
    "next": "16.2.6",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "react-icons": "^5.5.0"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "1.37.1",
    "@cloudflare/workers-types": "^4.20260702.1",
    "@tailwindcss/postcss": "4.2.1",
    "@types/node": "22.19.19",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "@vitejs/plugin-rsc": "0.5.26",
    "basic-ftp": "^6.0.1",
    "drizzle-kit": "0.31.10",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.6",
    "react-server-dom-webpack": "19.2.6",
    "tailwindcss": "4.2.1",
    "typescript": "5.9.3",
    "vinext": "0.0.50",
    "vite": "8.0.13",
    "wrangler": "4.92.0"
  },
  "type": "module"
}
